<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>

</head>
<body class="bg-zinc-900 text-white p-10">
    <h1 class="mb-5">Edit your post.</h1>
    <form action="/update/posts" method="post">
        <div >
            <textarea class=" mb-4 border border-zinc-700 rounded-md block w-1/3 p-2 resize-none" name="newContent" placeholder="what's in your mind."><%= post.content%></textarea>
            <input class="bg-yellow-400 text-black px-2 py-1 rounded-md" type="submit" value="Update post.">
        </div>
    </form>
    

</body>
</html>