<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Document</title>
    <script src="https://cdn.jsdelivr.net/npm/@tailwindcss/browser@4"></script>

</head>
<body class="bg-zinc-900 text-white p-10 ">
    <div class=" flex justify-between mb-5">
         <div class="flex gap-2">
            <div class="w-7 max-w-sm rounded-lg shadow-md object-cover overflow-hidden">
                <a href="/edit/profile/<%= user._id %>"><img src="/images/uploads/<%= user.profile %>" alt="profile_pic"></a>
            </div>
            <h1 class="text-4xl">Welcome, <%= user.name %> 👋</h1>
         </div>
        <a  class=" bg-red-400 inline px-3 py-1 rounded-md" href="/logout">logout</a>

    </div>
    <h1 class="mb-2">Create your posts here.</h1>
    <form action="/posts" method="post">
        <div class="mb-10" >
            <textarea class=" mb-2 border border-zinc-700 rounded-md block w-1/3 p-2 resize-none" name="content" placeholder="what's in your mind."></textarea>
            <input class="bg-blue-600 px-2 py-1 rounded-md" type="submit" value="Create post.">
        </div>
    </form>
    <div >
        <h1 class="inline-block text-lg mb-3 ">Your post.</h1>
        <div class="flex gap-2 flex-wrap  h-72">
            <% user.post.forEach(function(post){ %>
            <div class="w-1/3 h-35 border border-zinc-700 rounded py-2 px-3 flex flex-col justify-between">
                <h1 class="text-blue-400">@<%= user.name%></h1>
                <h1 class="tracking-tight mb-1  overflow-y-auto"><%= post.content%></h1>
                <p class="inline text-blue-300"><%= post.like.length %></p>
                <div class="flex gap-7">
                    <a class="text-blue-300" href="/profile/like/<%= post._id %>"><%= post.like.indexOf(user._id) ===-1 ? "Like" : "Unlike" %></a>
                    <a class="text-zinc-700" href="/profile/edit/<%= post._id %>">edit</a>
                    <a class="text-red-400 " href="/profile/delete/<%= post._id %>">Delete</a>
                </div>
            </div>
            <% }) %>
        </div>
    </div>
    

</body>
</html>